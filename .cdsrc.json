{
  "build": {
    "target": "gen",
    "tasks": [
      {
        "for": "postgres",
        "src": "db",
        "options": {
          "model": [
            "db",
            "!@sap/cds/srv/outbox"
          ]
        }
      },
      {
        "for": "node-cf",
        "src": "srv",
        "options": {
          "model": [
            "srv",
            "@sap/cds/srv/outbox"
          ]
        }
      }
    ]
  },
  "requires": {
    "db": {
      "kind": "postgres"
    }
  }
}